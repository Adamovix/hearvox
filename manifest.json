{
  "manifest_version": 3,
  "name": "Hearvox TTS",
  "version": "1.0.1",
  "description": "Read aloud selected text using text-to-speech (TTS). Supports ElevenLabs API.",
  "browser_specific_settings": {
    "gecko": {
      "id": "hearvox@adamovix.pl",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "menus",
    "storage",
    "notifications"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Hearvox TTS Settings"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
